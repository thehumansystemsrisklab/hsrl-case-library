{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/diagnostic",
      "destination": "/diagnostic.html"
    },
    {
      "source": "/((?!api/|diagnostic(\\.html)?$|index\\.html$|cases-data\\.json$|cases-content-[^/]+\\.json$|package\\.json$|vercel\\.json$)[^/]+)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.json)",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ]
}

{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/diagnostic",
      "dest": "/diagnostic.html"
    },
    {
      "src": "/([^.]+)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*).json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ]
}

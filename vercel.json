{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/:slug((?!diagnostic)[^.]+)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*).json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ]
}
